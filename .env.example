# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# ─── OpenAI OAuth (PKCE – no API key stored) ──────────────────────────────────
OPENAI_OAUTH_CLIENT_ID=your_openai_oauth_client_id
OPENAI_OAUTH_CLIENT_SECRET=your_openai_oauth_client_secret
OPENAI_REDIRECT_URI=http://localhost:8080/callback

# ─── Gemini CLI OAuth (Google) ────────────────────────────────────────────────
GEMINI_OAUTH_CLIENT_ID=your_google_oauth_client_id
GEMINI_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# Same redirect as OpenAI (one server handles all)

# ─── Antigravity (Google DeepMind) OAuth ─────────────────────────────────────
ANTIGRAVITY_CLIENT_ID=your_antigravity_client_id
ANTIGRAVITY_CLIENT_SECRET=your_antigravity_client_secret

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8435117487:AAGOAgK2gJ9OxsGsnQ9bXbwcgSmKvTSIIOI
TELEGRAM_CHAT_ID=7764037225

# ─── Optional External APIs ───────────────────────────────────────────────────
DEXSCREENER_API=
BIRDEYE_API=
COINGECKO_API=

# ─── Bot Config ───────────────────────────────────────────────────────────────
DRY_RUN=true
SCAN_INTERVAL_SEC=30
MAX_POSITION_PCT=5
MAX_DAILY_LOSS_PCT=10
MAX_LEVERAGE=5
LOG_LEVEL=INFO
